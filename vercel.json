{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build && node api/_build.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
